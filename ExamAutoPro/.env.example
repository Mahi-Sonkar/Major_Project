# Django Settings
SECRET_KEY=your-secret-key-here-change-in-production
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# Database Configuration
DB_NAME=examautoprob
DB_USER=postgres
DB_PASSWORD=password
DB_HOST=localhost
DB_PORT=5432

# Email Configuration
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=your-email@gmail.com
EMAIL_HOST_PASSWORD=your-app-password
DEFAULT_FROM_EMAIL=your-email@gmail.com

# Redis Configuration (for caching and celery)
REDIS_URL=redis://localhost:6379/0

# Celery Configuration
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0

# File Upload Settings
MAX_UPLOAD_SIZE=10485760  # 10MB in bytes

# AI/ML Model Paths
OCR_ENGINE=tesseract
NLP_MODEL_PATH=./ai_models
FACE_DETECTION_MODEL=./ai_models/face_detection

# Proctoring Settings
PROCTORING_ENABLED=True
TAB_SWITCH_DETECTION=True
FACE_DETECTION_ENABLED=True
SCREEN_RECORDING_ENABLED=False
AUDIO_MONITORING_ENABLED=False

# Security Settings
SECURE_SSL_REDIRECT=False
SECURE_HSTS_SECONDS=0
SECURE_HSTS_INCLUDE_SUBDOMAINS=False
SECURE_HSTS_PRELOAD=False

# Logging
LOG_LEVEL=INFO
LOG_FILE=./logs/examautopro.log

# API Keys (if needed)
# OPENAI_API_KEY=your-openai-key
# GOOGLE_CLOUD_API_KEY=your-google-cloud-key
# Required for handwritten PDF analysis (Google Lens style OCR)
GOOGLE_APPLICATION_CREDENTIALS=D:\ExamAutoPro\ocr-key.json
ANTHROPIC_API_KEY=sk-ant-api03-your-key-here
TESSERACT_CMD=C:\Program Files\Tesseract-OCR\tesseract.exe

# Third-party Services
# SENTRY_DSN=your-sentry-dsn
